# Secrets must never enter this repo. The PAT lives in the browser's localStorage,
# the password in memory / GL_PASSWORD env only.
.env
.env.*
*.pem
*.token

# No markdown on the public repo, ever. All of it — pedagogy, docs, notes — is
# local-only (the repo is public; these can hold personal/architectural detail).
# Blanket-ignored so nothing new gets committed by accident; the named files
# below are kept for clarity. Encrypted lessons are *.md.enc, unaffected.
*.md
Deutsch_Sprachstand_Bericht.md
Frau_Richter_Persona.md
Studienplan.md
SCHEMA.md
LEARNING_LOOP.md
README.md

# Plaintext lesson/homework sources — only the encrypted .enc versions under
# docs/data/ get committed.
scripts/templates/

# Node / OS noise
node_modules/
.DS_Store

# Local tooling
.claude/

# Frau Richter's private memory — judgment carried across runs. Never commit.
frau_richter/

# Her feature-request drawer — read and implemented by the development sessions.
feature requests.md
